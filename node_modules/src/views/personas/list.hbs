<div class="container">
  <div class="row mt-5">
    <h3 class="text-center text-uppercase p-2">Lista de Personas</h3>

    {{#if personas}}
    <table class="table text-center table-striped align-middle">
      <thead>
        <tr class="table-dark">
          <th scope="col" class="col-4">Nombre</th>
          <th scope="col">Apellido</th>
          <th scope="col">Edad</th>
          <th scope="col">Acciones</th>
        </tr>
      </thead>
      <tbody>
        {{#each personas}}
        <tr>
          <td>{{name}}</td>
          <td>{{lastname}}</td>
          <td>{{age}}</td>
          <td>
            <div class="btn-group" role="group">
              <a href="/edit/{{id}}" class="btn btn-warning btn-sm" title="Editar">
                <i class="fa-solid fa-pencil"></i>
              </a>
              <a href="/delete/{{id}}" class="btn btn-danger btn-sm" title="Eliminar"
                onclick="return confirm('¿Deseas eliminar este registro?')">
                <i class="fa-solid fa-trash"></i>
              </a>

              </a>
            </div>
          </td>
        </tr>
        {{/each}}
      </tbody>
      <tfoot>
        <tr class="table-dark">
          <td colspan="4">REGISTRO DE PERSONAS</td>
        </tr>
      </tfoot>
    </table>
    {{else}}
    <div class="card text-center mx-auto" style="width: 22rem;">
      <div class="card-header">
        <h3>No hay personas registradas</h3>
      </div>
      <div class="card-body">
        <p>Presiona este botón para registrar una nueva persona en la aplicación.</p>
        <a href="/add" class="btn btn-primary">
          <i class="fa-solid fa-user-plus"></i> Crear Persona
        </a>
      </div>
    </div>
    {{/if}}
  </div>
</div>